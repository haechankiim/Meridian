# Meridian — Environment Variables
# Copy to .env and fill in your keys

MERIDIAN_DATABASE_URL=postgresql+asyncpg://meridian:meridian@localhost:5432/meridian
MERIDIAN_REDIS_URL=redis://localhost:6379/0

# Alpha Vantage (free: https://www.alphavantage.co/support/#api-key)
MERIDIAN_ALPHA_VANTAGE_KEY=your_key_here

# Binance (optional — public endpoints work without keys)
MERIDIAN_BINANCE_API_KEY=
MERIDIAN_BINANCE_API_SECRET=

# App
MERIDIAN_DEBUG=true
